{
  "$schema": "http://json.schemastore.org/template",
  "author": "SeuTime",
  "classifications": ["Web", "API", "Hexagonal", "Architecture"],
  "identity": "Company.Hexagonal.Template",
  "name": "Hexagonal Architecture API",
  "shortName": "hexagonal",
  "tags": {
    "language": "C#",
    "type": "project"
  },
  "sourceName": "__ProjectName__",
  "preferNameDirectory": true,

  "sources": [
    {
      "exclude": [
        "**/.git/**",
        "**/.vscode/**",
        "**/.template.config/**",
        "**/.idea/**",
        "**/.DS_Store",
        "**/bin/**",
        "**/obj/**",
        "**/*.user",
        "**/*.suo",
        "**/*.log",
        "**/hexagonal-template.nuspec",
        "**/README.md"
      ]
    }
  ]
}